{
  "manifest_version": 3,
  "name": "Celestial Nexus Hangar Sync",
  "version": "1.2.1",
  "description": "Locally scans the signed-in RSI My Hangar page and shares a user-approved fleet snapshot with Celestial Nexus.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://robertsspaceindustries.com/account/pledges*",
    "https://www.robertsspaceindustries.com/account/pledges*",
    "https://elusyon117.github.io/celestial-alliance-nexus-tool-kit/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://robertsspaceindustries.com/account/pledges*",
        "https://www.robertsspaceindustries.com/account/pledges*"
      ],
      "js": [
        "content-rsi.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://elusyon117.github.io/celestial-alliance-nexus-tool-kit/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "bridge-toolkit.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Celestial Nexus Hangar Sync",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "homepage_url": "https://elusyon117.github.io/celestial-alliance-nexus-tool-kit/",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
